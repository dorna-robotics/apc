  attach:
    parent_name: "fixture_plate_4"
    parent_solid: "body"
    parent_anchor: "D5"
    child_solid: "body"
    child_anchor: "hole_1"
    offset: [0, 0, 0, 0, 0, 0]

stack_holder_disc_out_good_2:
