# apc — layout on the shared core_500 chassis.
# Devices/components attach to the fixture plates from scene/core_500.j2.
#
# Contents:
#   - tool rack + suction-cup gripper (to pick/place discs)
#   - multimeter (BK 879B) on plate 1
#   - anode on plate 1
#   - rotating cylinder + cathode riding its plunger (as in the old apc)
#   - disc adapters on plate 4: 2 IN sources + 3 OUT sinks
#       in:  in_1, in_2
#       out: good_1, good_2  (accepted discs)  +  bad_1  (rejected discs)
#
# This commit is scene-first — actions/recipes are the Start/Park scaffold
# only; the pick → measure → sort workflow gets wired next.

# ── Tooling ─────────────────────────────────────────────────────────
# No tool rack in this cell — the suction gripper is mounted directly on
# the robot (its tool-changer side mates to the Core's tool_changer_robot_side).
gripper_suction_1:
  type: "gripper_suction"
  has_tool_changer: true
  attach:
    parent_name: "core"
    parent_solid: "tool_changer_robot_side"
    parent_anchor: "tool_changer_connection"
    child_solid: "tool_changer_tool_side"
    child_anchor: "tool_changer_connection"
    offset: [0, 0, 0, 0, 0, 0]

# ── Multimeter (BK 879B) ────────────────────────────────────────────
# Sim by default; for the real meter set port + simulation:false (see
# device-guide §9: ls -d /dev/serial/by-id/* for the stable path).
multi_meter_1:
  type: "multi_meter_bk879b"
  port: ""
  simulation: true
  critical: true
  attach:
    parent_name: "fixture_plate_1"
    parent_solid: "body"
    parent_anchor: "E10"
    child_solid: "body"
    child_anchor: "center"
    offset: [0, 0, 0, 0, 0, 0]

# ── Anode ───────────────────────────────────────────────────────────
anode_1:
  type: "anode"
  attach:
    parent_name: "fixture_plate_1"
    parent_solid: "body"
    parent_anchor: "D19"
    child_solid: "body"
    child_anchor: "hole_0"
    offset: [0, 0, 0, 0, 0, 90]

# ── Rotating cylinder + cathode (cathode rides the plunger) ─────────
rotating_cylinder_mkb1630_1:
  type: "rotating_cylinder_mkb1630"
  output_enable: [[0, 1, 0]]
  output_disable: [[0, 0, 0]]
  attach:
    parent_name: "fixture_plate_1"
    parent_solid: "body"
    parent_anchor: "F16"
    child_solid: "housing"
    child_anchor: "hole_0"
    offset: [0, 0, 0, 0, 0, 90]

cathode_1:
  type: "cathode"
  attach:
    parent_name: "rotating_cylinder_mkb1630_1"
    parent_solid: "plunger"
    parent_anchor: "place"
    child_solid: "body"
    child_anchor: "center"
    offset: [0, 0, 0, 0, 0, 0]

# ── Inspection (horizontal vision station) ──────────────────────────
inspection_horizontal_1:
  type: "inspection_horizontal"
  attach:
    parent_name: "fixture_plate_4"
    parent_solid: "body"
    parent_anchor: "A2"
    child_solid: "body"
    child_anchor: "hole_0"
    offset: [0, 0, 0, 0, 0, 0]

# ── Disc adapters on plate 4 ────────────────────────────────────────
# Each disc holder is an adapter_disc_holder mounted on a plate hole,
# with a stack_holder on the adapter's "place" anchor. 2 IN + 3 OUT.

# --- IN source 1 ---
adapter_disc_in_1:
  type: "adapter_disc_holder"
  attach:
    parent_name: "fixture_plate_4"
    parent_solid: "body"
    parent_anchor: "J5"
    child_solid: "body"
    child_anchor: "hole_1"
    offset: [0, 0, 0, 0, 0, 0]

stack_holder_disc_in_1:
  type: "stack_holder_disc_in"
  attach:
    parent_name: "adapter_disc_in_1"
    parent_solid: "body"
    parent_anchor: "place"
    child_solid: "body"
    child_anchor: "center"
    offset: [0, 0, 0, 0, 0, 0]

# --- IN source 2 ---
adapter_disc_in_2:
  type: "adapter_disc_holder"
  attach:
    parent_name: "fixture_plate_4"
    parent_solid: "body"
    parent_anchor: "H5"
    child_solid: "body"
    child_anchor: "hole_1"
    offset: [0, 0, 0, 0, 0, 0]

stack_holder_disc_in_2:
  type: "stack_holder_disc_in"
  attach:
    parent_name: "adapter_disc_in_2"
    parent_solid: "body"
    parent_anchor: "place"
    child_solid: "body"
    child_anchor: "center"
    offset: [0, 0, 0, 0, 0, 0]

# --- OUT good 1 ---
adapter_disc_out_good_1:
  type: "adapter_disc_holder"
  attach:
